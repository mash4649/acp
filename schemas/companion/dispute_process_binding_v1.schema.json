{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:acp:schemas:companion:dispute_process_binding_v1",
  "title": "dispute_process_binding_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "binding_type",
    "binding_version",
    "process_id",
    "challenge_window_ref",
    "created_at"
  ],
  "properties": {
    "binding_type": {
      "const": "dispute_process_binding_v1"
    },
    "binding_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "process_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "challenge_window_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    }
  }
}
