{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:acp:schemas:core:proof_finality_v1",
  "title": "proof_finality_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "protocol_version",
    "agreement_id",
    "revision_id",
    "finality_id",
    "proof_id",
    "status",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "proof_finality_v1"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "agreement_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "revision_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "finality_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "proof_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "finalized_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    }
  }
}
