{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:acp:schemas:core:delegation_edge_v1",
  "title": "delegation_edge_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "protocol_version",
    "agreement_id",
    "revision_id",
    "edge_id",
    "parent_revision_id",
    "child_agreement_id",
    "child_revision_id",
    "parent_subject_ref",
    "child_subject_ref",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "delegation_edge_v1"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "agreement_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "revision_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "edge_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "parent_revision_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "child_agreement_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "child_revision_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "parent_subject_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "child_subject_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    }
  }
}
