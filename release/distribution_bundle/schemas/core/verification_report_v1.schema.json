{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:acp:schemas:core:verification_report_v1",
  "title": "verification_report_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "protocol_version",
    "agreement_id",
    "revision_id",
    "verification_id",
    "integrity_decision",
    "acceptance_decision",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "verification_report_v1"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "agreement_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "revision_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "verification_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "integrity_decision": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "acceptance_decision": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    }
  }
}
