{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:acp:schemas:core:proof_artifact_v1",
  "title": "proof_artifact_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "protocol_version",
    "agreement_id",
    "revision_id",
    "proof_id",
    "statement_hash",
    "proof_payload_hash",
    "verifier_ref",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "proof_artifact_v1"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "agreement_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "revision_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "proof_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "statement_hash": {
      "type": "string",
      "minLength": 1,
      "pattern": "^sha256:[A-Za-z0-9._-]+$"
    },
    "proof_payload_hash": {
      "type": "string",
      "minLength": 1,
      "pattern": "^sha256:[A-Za-z0-9._-]+$"
    },
    "verifier_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    }
  }
}
