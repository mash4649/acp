{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:acp:schemas:core:freeze_record_v1",
  "title": "freeze_record_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "protocol_version",
    "agreement_id",
    "revision_id",
    "freeze_id",
    "state_commitment",
    "evidence_commitment",
    "event_commitment",
    "frozen_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "freeze_record_v1"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "agreement_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "revision_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "freeze_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:/-]+$"
    },
    "state_commitment": {
      "type": "string",
      "minLength": 1,
      "pattern": "^sha256:[A-Za-z0-9._-]+$"
    },
    "evidence_commitment": {
      "type": "string",
      "minLength": 1,
      "pattern": "^sha256:[A-Za-z0-9._-]+$"
    },
    "event_commitment": {
      "type": "string",
      "minLength": 1,
      "pattern": "^sha256:[A-Za-z0-9._-]+$"
    },
    "frozen_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    }
  }
}
