{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_id": "acp-conformance-harness-contract-v1",
  "version": "1.0.0",
  "intent": "Thin adapter contract for ACP schema and invariant conformance execution",
  "scope": {
    "in_scope": [
      "vector-driven schema conformance execution",
      "case-driven protocol invariant execution",
      "deterministic report shape",
      "profile-driven run metadata"
    ],
    "out_of_scope": [
      "execution framework behavior",
      "transport protocol behavior",
      "payment rail semantics"
    ]
  },
  "required_separations": [
    "prompt_is_not_contract",
    "claim_is_not_evidence",
    "verification_is_not_settlement"
  ],
  "runner_cli": {
    "runner_env_var": "ACP_HARNESS_RUNNER",
    "required_args": [
      "--contract",
      "--profile",
      "--request",
      "--report"
    ]
  },
  "artifacts": {
    "run_request": {
      "format": "application/json",
      "description": "Generated by repo adapter before invoking external or reference runner"
    },
    "run_report": {
      "format": "application/json",
      "must_conform_to": "conformance/report.schema.json"
    }
  },
  "invariants": [
    "append_only_history_modeled_as_artifacts_not_mutation",
    "policy_evaluation_inputs_must_be_replayable",
    "core_and_companion_surfaces_must_remain_separate",
    "reference_harness_is_baseline_not_external_authority"
  ]
}
